{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "make: build",
            "type": "shell",
            "command": "make",
            "args": [
                "all"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": "$gcc",
            "detail": "Run make all."
        },
        {
            "label": "make: clean",
            "type": "shell",
            "command": "make",
            "args": [
                "clean"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [],
            "detail": "Run make clean."
        },
        {
            "label": "make: rebuild",
            "type": "shell",
            "command": "make",
            "args": [
                "rebuild"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "build",
            "problemMatcher": "$gcc",
            "detail": "Run make rebuild."
        },
        {
            "label": "make: run",
            "type": "shell",
            "command": "make",
            "args": [
                "run"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": "$gcc",
            "detail": "Run make run."
        }
    ]
}
